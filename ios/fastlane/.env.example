# Copy to ios/fastlane/.env and fill in (do not commit .env)
#
# Use KEY_ID, ISSUER_ID, and KEY_PATH only — do NOT set APP_STORE_CONNECT_API_KEY.

# Recommended: App Store Connect API key
# Create at https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_PATH=/absolute/path/to/AuthKey_XXXXXX.p8

# Alternative: Apple ID + app-specific password
# APPLE_ID=you@example.com
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
